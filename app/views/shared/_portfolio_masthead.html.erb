<section class="jumbotron text-center" style="background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; padding: 60px 20px; border-radius: 12px; box-shadow: 0 6px 20px rgba(0,0,0,0.3);">
  <div class="container">
    
    <h1 class="jumbotron-heading" 
        style="font-family: 'Poppins', sans-serif; font-size: 48px; font-weight: 700; margin-bottom: 20px;">
      🎨 My Portfolio
    </h1>

    <p class="lead text-light" 
       style="font-size: 18px; max-width: 750px; margin: 0 auto 30px auto; line-height: 1.7;">
      👋 Welcome! This is a showcase of my <strong>projects</strong>, <strong>ideas</strong>, and <strong>creations</strong>.  
      🚀 Each project reflects my passion for <em>innovation, clean design,</em> and <em>scalable code</em>.  
      🌟 Take a look and discover what I’ve been working on!
    </p>

    <p>
      <%= link_to "🙋‍♂️ About Me", about_path, 
          class: "btn btn-lg fw-bold", 
          style: "background: #ff9800; color: white; border-radius: 50px; padding: 12px 26px; margin: 5px; border: none;" %>

      <%= link_to "📝 My Blog", blogs_path, 
          class: "btn btn-lg fw-bold", 
          style: "background: #4caf50; color: white; border-radius: 50px; padding: 12px 26px; margin: 5px; border: none;" %>
    </p>

  </div>
</section>
